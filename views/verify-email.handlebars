<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Verify Your Email - Buckety</title>

    <style>
        /* Reset styles */
        body,
        table,
        td,
        a {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table,
        td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        img {
            -ms-interpolation-mode: bicubic;
            border: 0;
            height: auto;
            line-height: 100%;
            outline: none;
            text-decoration: none;
        }

        body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            height: 100% !important;
        }

        /* Design System Colors */
        :root {
            --sage: #8B9A7E;
            --dark-sage: #6B7A5E;
            --gold: #D4A574;
            --light-gold: #E8D4B8;
            --cream: #FAF7F2;
            --white: #FFFFFF;
            --charcoal: #2C3E3F;
            --text-secondary: #5A6C6D;
            --text-tertiary: #8A9B9C;
            --border-light: #E8EDED;
            --danger: #C76D6D;
        }

        /* Email Container */
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #FAF7F2;
        }

        /* Header */
        .email-header {
            background: linear-gradient(135deg, #8B9A7E 0%, #6B7A5E 100%);
            padding: 40px 20px;
            text-align: center;
        }

        .logo-container {
            display: inline-block;
            background: #FFFFFF;
            padding: 12px 20px;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(44, 62, 63, 0.15);
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            display: inline-block;
            vertical-align: middle;
            margin-right: 10px;
        }

        .logo-text {
            display: inline-block;
            vertical-align: middle;
            font-family: 'Georgia', serif;
            font-size: 28px;
            font-weight: 700;
            color: #2C3E3F;
            letter-spacing: -0.5px;
        }

        /* Main Content */
        .email-body {
            background: #FFFFFF;
            padding: 40px 30px;
            margin: 0;
        }

        .greeting {
            font-family: 'Georgia', serif;
            font-size: 28px;
            font-weight: 700;
            color: #2C3E3F;
            margin: 0 0 20px 0;
            line-height: 1.3;
        }

        .message {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 16px;
            color: #5A6C6D;
            line-height: 1.6;
            margin: 0 0 30px 0;
        }

        .message strong {
            color: #2C3E3F;
            font-weight: 600;
        }

        /* Verification Box */
        .verification-box {
            background: linear-gradient(135deg, #FAF7F2 0%, #FFFFFF 100%);
            border: 2px solid #E8D4B8;
            border-radius: 16px;
            padding: 30px;
            margin: 30px 0;
            text-align: center;
        }

        .verification-title {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #8A9B9C;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0 0 15px 0;
        }

        /* CTA Button */
        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #8B9A7E 0%, #6B7A5E 100%);
            color: #FFFFFF !important;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            padding: 16px 40px;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(139, 154, 126, 0.3);
            transition: all 0.3s ease;
            margin: 10px 0;
        }

        .cta-button:hover {
            background: linear-gradient(135deg, #6B7A5E 0%, #5A6C6D 100%);
            box-shadow: 0 6px 16px rgba(139, 154, 126, 0.4);
        }

        /* Alternative Link */
        .alternative-link {
            margin-top: 20px;
        }

        .alternative-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 13px;
            color: #8A9B9C;
            margin: 0 0 10px 0;
        }

        .verification-link {
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            color: #6B7A5E;
            word-break: break-all;
            background: #FAF7F2;
            padding: 12px 16px;
            border-radius: 8px;
            border: 1px solid #E8EDED;
            display: block;
            text-decoration: none;
        }

        /* Info Box */
        .info-box {
            background: rgba(139, 154, 126, 0.05);
            border-left: 4px solid #8B9A7E;
            padding: 20px;
            margin: 30px 0;
            border-radius: 8px;
        }

        .info-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #5A6C6D;
            line-height: 1.6;
            margin: 0;
        }

        .info-icon {
            display: inline-block;
            width: 20px;
            height: 20px;
            vertical-align: middle;
            margin-right: 8px;
            color: #8B9A7E;
        }

        /* Expiry Warning */
        .expiry-warning {
            background: rgba(212, 165, 116, 0.1);
            border: 1px solid #D4A574;
            border-radius: 8px;
            padding: 15px 20px;
            margin: 20px 0;
            text-align: center;
        }

        .expiry-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #2C3E3F;
            margin: 0;
            font-weight: 600;
        }

        .expiry-icon {
            display: inline-block;
            width: 16px;
            height: 16px;
            vertical-align: middle;
            margin-right: 6px;
            color: #D4A574;
        }

        /* Help Section */
        .help-section {
            text-align: center;
            margin: 30px 0;
        }

        .help-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #8A9B9C;
            margin: 0 0 10px 0;
        }

        .help-link {
            color: #8B9A7E;
            text-decoration: none;
            font-weight: 600;
        }

        .help-link:hover {
            text-decoration: underline;
        }

        /* Footer */
        .email-footer {
            background: #FAF7F2;
            padding: 30px 20px;
            text-align: center;
            border-top: 1px solid #E8EDED;
        }

        .footer-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 13px;
            color: #8A9B9C;
            line-height: 1.6;
            margin: 0 0 15px 0;
        }

        .footer-links {
            margin: 15px 0;
        }

        .footer-link {
            color: #8B9A7E;
            text-decoration: none;
            font-size: 13px;
            margin: 0 10px;
            font-weight: 500;
        }

        .footer-link:hover {
            text-decoration: underline;
        }

        .social-links {
            margin: 20px 0 10px 0;
        }

        .social-icon {
            display: inline-block;
            width: 32px;
            height: 32px;
            margin: 0 8px;
            opacity: 0.6;
            transition: opacity 0.3s ease;
        }

        .social-icon:hover {
            opacity: 1;
        }

        .copyright {
            font-size: 12px;
            color: #8A9B9C;
            margin: 15px 0 0 0;
        }

        /* Responsive */
        @media only screen and (max-width: 600px) {
            .email-body {
                padding: 30px 20px !important;
            }

            .greeting {
                font-size: 24px !important;
            }

            .message {
                font-size: 15px !important;
            }

            .verification-box {
                padding: 20px !important;
            }

            .cta-button {
                padding: 14px 30px !important;
                font-size: 15px !important;
                display: block !important;
                width: 100% !important;
                box-sizing: border-box !important;
            }

            .verification-link {
                font-size: 11px !important;
            }

            .email-header {
                padding: 30px 20px !important;
            }

            .logo-text {
                font-size: 24px !important;
            }
        }
    </style>
</head>

<body style="margin: 0; padding: 0; background-color: #FAF7F2;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
        style="background-color: #FAF7F2;">
        <tr>
            <td style="padding: 20px 0;">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" class="email-container"
                    align="center" width="600"
                    style="margin: 0 auto; background-color: #FFFFFF; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 24px rgba(44, 62, 63, 0.12);">

                    <!-- Header -->
                    <tr>
                        <td class="email-header">
                            <div class="logo-container">
                                <svg class="logo-icon" width="40" height="40" viewBox="0 0 24 24" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4" stroke="#8B9A7E"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M4 6v12c0 1.1.9 2 2 2h14v-4" stroke="#8B9A7E" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z" stroke="#8B9A7E"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <span class="logo-text">Buckety</span>
                            </div>
                        </td>
                    </tr>

                    <!-- Main Content -->
                    <tr>
                        <td class="email-body">
                            <h1 class="greeting">Welcome to Buckety! 👋</h1>

                            <p class="message">
                                Hi <strong>{{name}}</strong>,
                            </p>

                            <p class="message">
                                Thank you for creating your Buckety account! We're excited to help you take control of
                                your finances with our envelope budgeting system.
                            </p>

                            <p class="message">
                                To get started and access all features, please verify your email address by clicking the
                                button below:
                            </p>

                            <!-- Verification Box -->
                            <div class="verification-box">
                                <p class="verification-title">Click to Verify Your Email</p>
                                <a href={{email}} class="cta-button">Verify Email
                                    Address</a>

                                <div class="alternative-link">
                                    <p class="alternative-text">Or copy and paste this link into your browser:</p>
                                    <a href={{verificationLink}} class="verification-link">{{verificationLink}}</a>
                                </div>
                            </div>

                            <!-- Expiry Warning -->
                            <div class="expiry-warning">
                                <p class="expiry-text">
                                    <svg class="expiry-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                                        <polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    This verification link expires in 24 hours
                                </p>
                            </div>

                            <!-- Info Box -->
                            <div class="info-box">
                                <p class="info-text">
                                    <svg class="info-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                                        <line x1="12" y1="16" x2="12" y2="12" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" />
                                        <line x1="12" y1="8" x2="12.01" y2="8" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" />
                                    </svg>
                                    <strong>Why verify your email?</strong><br>
                                    Email verification helps us protect your account, send you important notifications
                                    about your budget, and ensure you can recover your account if needed.
                                </p>
                            </div>

                            <p class="message">
                                Once verified, you'll be able to:
                            </p>

                            <p class="message" style="margin-left: 20px;">
                                ✓ Create and manage budget envelopes<br>
                                ✓ Track your income and expenses<br>
                                ✓ Set spending goals and limits<br>
                                ✓ View detailed analytics and reports<br>
                                ✓ Sync across all your devices
                            </p>

                            <!-- Help Section -->
                            <div class="help-section">
                                <p class="help-text">
                                    Didn't create this account? You can safely ignore this email.
                                </p>
                                <p class="help-text">
                                    Need help? <a href="mailto:support@buckety.app" class="help-link">Contact our
                                        support team</a>
                                </p>
                            </div>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td class="email-footer">
                            <p class="footer-text">
                                <strong>Buckety</strong> - Smart Envelope Budgeting<br>
                                Take control of your money, one envelope at a time.
                            </p>

                            <div class="footer-links">
                                <a href="https://buckety.app" class="footer-link">Home</a>
                                <a href="https://buckety.app/features" class="footer-link">Features</a>
                                <a href="https://buckety.app/help" class="footer-link">Help Center</a>
                                <a href="https://buckety.app/privacy" class="footer-link">Privacy</a>
                            </div>

                            <div class="social-links">
                                <a href="https://twitter.com/buckety" style="text-decoration: none;">
                                    <svg class="social-icon" width="32" height="32" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <path
                                            d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
                                            stroke="#8B9A7E" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round" />
                                    </svg>
                                </a>
                                <a href="https://facebook.com/buckety" style="text-decoration: none;">
                                    <svg class="social-icon" width="32" height="32" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                                            stroke="#8B9A7E" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round" />
                                    </svg>
                                </a>
                                <a href="https://instagram.com/buckety" style="text-decoration: none;">
                                    <svg class="social-icon" width="32" height="32" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="#8B9A7E"
                                            stroke-width="2" />
                                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" stroke="#8B9A7E"
                                            stroke-width="2" />
                                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="#8B9A7E" stroke-width="2"
                                            stroke-linecap="round" />
                                    </svg>
                                </a>
                            </div>

                            <p class="copyright">
                                © 2026 Buckety. All rights reserved.<br>
                                123 Finance Street, Accra, Ghana
                            </p>

                            <p class="footer-text" style="font-size: 11px; margin-top: 15px;">
                                You're receiving this email because you created an account at Buckety.<br>
                                <a href="https://buckety.app/unsubscribe"
                                    style="color: #8A9B9C; text-decoration: underline;">Unsubscribe from these
                                    emails</a>
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>

</html>