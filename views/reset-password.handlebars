<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Reset Your Password - Buckety</title>

    <style>
        /* Reset styles */
        body,
        table,
        td,
        a {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table,
        td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        img {
            -ms-interpolation-mode: bicubic;
            border: 0;
            height: auto;
            line-height: 100%;
            outline: none;
            text-decoration: none;
        }

        body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            height: 100% !important;
        }

        /* Design System Colors */
        :root {
            --gold: #D4A574;
            --dark-gold: #C89A5E;
            --cream: #FAF7F2;
            --white: #FFFFFF;
            --charcoal: #2C3E3F;
            --text-secondary: #5A6C6D;
            --text-tertiary: #8A9B9C;
            --border-light: #E8EDED;
            --danger: #C76D6D;
        }

        /* Email Container */
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #FAF7F2;
        }

        /* Header */
        .email-header {
            background: linear-gradient(135deg, #D4A574 0%, #C89A5E 100%);
            padding: 40px 20px;
            text-align: center;
        }

        .logo-container {
            display: inline-block;
            background: #FFFFFF;
            padding: 12px 20px;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(44, 62, 63, 0.15);
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            display: inline-block;
            vertical-align: middle;
            margin-right: 10px;
        }

        .logo-text {
            display: inline-block;
            vertical-align: middle;
            font-family: 'Georgia', serif;
            font-size: 28px;
            font-weight: 700;
            color: #2C3E3F;
            letter-spacing: -0.5px;
        }

        /* Main Content */
        .email-body {
            background: #FFFFFF;
            padding: 40px 30px;
            margin: 0;
        }

        .greeting {
            font-family: 'Georgia', serif;
            font-size: 28px;
            font-weight: 700;
            color: #2C3E3F;
            margin: 0 0 20px 0;
            line-height: 1.3;
        }

        .message {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 16px;
            color: #5A6C6D;
            line-height: 1.6;
            margin: 0 0 30px 0;
        }

        .message strong {
            color: #2C3E3F;
            font-weight: 600;
        }

        /* Reset Box */
        .reset-box {
            background: linear-gradient(135deg, #FAF7F2 0%, #FFFFFF 100%);
            border: 2px solid #D4A574;
            border-radius: 16px;
            padding: 30px;
            margin: 30px 0;
            text-align: center;
        }

        .reset-title {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #8A9B9C;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0 0 15px 0;
        }

        /* CTA Button */
        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #D4A574 0%, #C89A5E 100%);
            color: #FFFFFF !important;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            padding: 16px 40px;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(212, 165, 116, 0.3);
            margin: 10px 0;
        }

        .cta-button:hover {
            background: linear-gradient(135deg, #C89A5E 0%, #B8895A 100%);
            box-shadow: 0 6px 16px rgba(212, 165, 116, 0.4);
        }

        /* Alternative Link */
        .alternative-link {
            margin-top: 20px;
        }

        .alternative-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 13px;
            color: #8A9B9C;
            margin: 0 0 10px 0;
        }

        .reset-link {
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            color: #C89A5E;
            word-break: break-all;
            background: #FAF7F2;
            padding: 12px 16px;
            border-radius: 8px;
            border: 1px solid #E8EDED;
            display: block;
            text-decoration: none;
        }

        /* Warning Box */
        .warning-box {
            background: rgba(199, 109, 109, 0.1);
            border: 1px solid #C76D6D;
            border-radius: 8px;
            padding: 15px 20px;
            margin: 20px 0;
            text-align: left;
        }

        .warning-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #2C3E3F;
            margin: 0;
            line-height: 1.6;
        }

        .warning-icon {
            display: inline-block;
            width: 16px;
            height: 16px;
            vertical-align: middle;
            margin-right: 6px;
            color: #C76D6D;
        }

        /* Expiry Warning */
        .expiry-warning {
            background: rgba(212, 165, 116, 0.1);
            border: 1px solid #D4A574;
            border-radius: 8px;
            padding: 15px 20px;
            margin: 20px 0;
            text-align: center;
        }

        .expiry-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #2C3E3F;
            margin: 0;
            font-weight: 600;
        }

        .expiry-icon {
            display: inline-block;
            width: 16px;
            height: 16px;
            vertical-align: middle;
            margin-right: 6px;
            color: #D4A574;
        }

        /* Security Tips */
        .security-section {
            background: #FAF7F2;
            border-radius: 12px;
            padding: 25px;
            margin: 30px 0;
        }

        .security-title {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 16px;
            font-weight: 600;
            color: #2C3E3F;
            margin: 0 0 15px 0;
        }

        .security-list {
            margin: 0;
            padding-left: 20px;
        }

        .security-list li {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #5A6C6D;
            line-height: 1.6;
            margin-bottom: 8px;
        }

        /* Help Section */
        .help-section {
            text-align: center;
            margin: 30px 0;
        }

        .help-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            color: #8A9B9C;
            margin: 0 0 10px 0;
        }

        .help-link {
            color: #D4A574;
            text-decoration: none;
            font-weight: 600;
        }

        .help-link:hover {
            text-decoration: underline;
        }

        /* Footer */
        .email-footer {
            background: #FAF7F2;
            padding: 30px 20px;
            text-align: center;
            border-top: 1px solid #E8EDED;
        }

        .footer-text {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 13px;
            color: #8A9B9C;
            line-height: 1.6;
            margin: 0 0 15px 0;
        }

        .footer-links {
            margin: 15px 0;
        }

        .footer-link {
            color: #D4A574;
            text-decoration: none;
            font-size: 13px;
            margin: 0 10px;
            font-weight: 500;
        }

        .footer-link:hover {
            text-decoration: underline;
        }

        .copyright {
            font-size: 12px;
            color: #8A9B9C;
            margin: 15px 0 0 0;
        }

        /* Responsive */
        @media only screen and (max-width: 600px) {
            .email-body {
                padding: 30px 20px !important;
            }

            .greeting {
                font-size: 24px !important;
            }

            .message {
                font-size: 15px !important;
            }

            .reset-box {
                padding: 20px !important;
            }

            .cta-button {
                padding: 14px 30px !important;
                font-size: 15px !important;
                display: block !important;
                width: 100% !important;
                box-sizing: border-box !important;
            }

            .reset-link {
                font-size: 11px !important;
            }

            .email-header {
                padding: 30px 20px !important;
            }

            .logo-text {
                font-size: 24px !important;
            }
        }
    </style>
</head>

<body style="margin: 0; padding: 0; background-color: #FAF7F2;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
        style="background-color: #FAF7F2;">
        <tr>
            <td style="padding: 20px 0;">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" class="email-container"
                    align="center" width="600"
                    style="margin: 0 auto; background-color: #FFFFFF; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 24px rgba(44, 62, 63, 0.12);">

                    <!-- Header -->
                    <tr>
                        <td class="email-header">
                            <div class="logo-container">
                                <svg class="logo-icon" width="40" height="40" viewBox="0 0 24 24" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4" stroke="#D4A574"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M4 6v12c0 1.1.9 2 2 2h14v-4" stroke="#D4A574" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z" stroke="#D4A574"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <span class="logo-text">Buckety</span>
                            </div>
                        </td>
                    </tr>

                    <!-- Main Content -->
                    <tr>
                        <td class="email-body">
                            <h1 class="greeting">Reset Your Password 🔐</h1>

                            <p class="message">
                                Hi <strong>{{ name }}</strong>,
                            </p>

                            <p class="message">
                                We received a request to reset the password for your Buckety account. If you made this
                                request, click the button below to create a new password.
                            </p>

                            <!-- Reset Box -->
                            <div class="reset-box">
                                <p class="reset-title">Click to Reset Your Password</p>
                                <a href="{{tokenLink}}" class="cta-button">Reset Password</a>

                                <div class="alternative-link">
                                    <p class="alternative-text">Or copy and paste this link into your browser:</p>
                                    <a href="{{tokenLink}}" class="reset-link">{{tokenLink}}</a>
                                </div>
                            </div>

                            <!-- Expiry Warning -->
                            <div class="expiry-warning">
                                <p class="expiry-text">
                                    <svg class="expiry-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                                        <polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    This reset link will expire in 15 minutes
                                </p>
                            </div>

                            <!-- Warning Box -->
                            <div class="warning-box">
                                <p class="warning-text">
                                    <svg class="warning-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <path
                                            d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                                            stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round" />
                                        <line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round" />
                                        <line x1="12" y1="17" x2="12.01" y2="17" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <strong>Didn't request this?</strong><br>
                                    If you didn't request a password reset, you can safely ignore this email. Your
                                    password will remain unchanged.
                                </p>
                            </div>

                            <!-- Security Tips -->
                            <div class="security-section">
                                <h3 class="security-title">🛡️ Password Security Tips</h3>
                                <ul class="security-list">
                                    <li>Use at least 8 characters with a mix of letters, numbers, and symbols</li>
                                    <li>Avoid using personal information like your name or birthday</li>
                                    <li>Don't reuse passwords from other accounts</li>
                                    <li>Consider using a password manager to generate strong passwords</li>
                                </ul>
                            </div>

                            <!-- Help Section -->
                            <div class="help-section">
                                <p class="help-text">
                                    Need help or have questions?
                                </p>
                                <p class="help-text">
                                    <a href="mailto:support@buckety.app" class="help-link">Contact our support team</a>
                                </p>
                            </div>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td class="email-footer">
                            <p class="footer-text">
                                <strong>Buckety</strong> - Smart Envelope Budgeting<br>
                                Take control of your money, one envelope at a time.
                            </p>

                            <div class="footer-links">
                                <a href="https://buckety.app" class="footer-link">Home</a>
                                <a href="https://buckety.app/features" class="footer-link">Features</a>
                                <a href="https://buckety.app/help" class="footer-link">Help Center</a>
                                <a href="https://buckety.app/privacy" class="footer-link">Privacy</a>
                            </div>

                            <p class="copyright">
                                © 2026 Buckety. All rights reserved.<br>
                                123 Finance Street, Accra, Ghana
                            </p>

                            <p class="footer-text" style="font-size: 11px; margin-top: 15px;">
                                You're receiving this email because a password reset was requested for your account.<br>
                                If you didn't make this request, please <a href="mailto:support@buckety.app"
                                    style="color: #D4A574;">contact us immediately</a>.
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>

</html>